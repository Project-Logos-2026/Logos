{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ARCHON_PRIME Implementation Guide Schema",
  "description": "Validates the structure of implementation guide artifacts",
  "type": "object",
  "required": [
    "guide_identity",
    "overview",
    "prerequisites",
    "stages",
    "governance_enforcement_points"
  ],
  "properties": {
    "guide_identity": {
      "type": "object",
      "required": ["subsystem", "version", "status", "source_specification", "author", "date"],
      "properties": {
        "subsystem": { "type": "string" },
        "version": { "type": "string", "pattern": "^v[0-9]+$" },
        "status": {
          "type": "string",
          "enum": ["draft", "under_review", "approved"]
        },
        "source_specification": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "approved_by": { "type": ["string", "null"] }
      }
    },
    "overview": { "type": "string", "minLength": 1 },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dependency", "status"],
        "properties": {
          "dependency": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["exists", "pending", "deferred"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage_number", "name", "objective", "files", "steps", "validation"],
        "properties": {
          "stage_number": { "type": "integer", "minimum": 1 },
          "name": { "type": "string" },
          "objective": { "type": "string" },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": { "type": "string" },
                "action": {
                  "type": "string",
                  "enum": ["create", "modify", "delete"]
                },
                "description": { "type": "string" }
              }
            }
          },
          "steps": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "validation": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "minItems": 1
    },
    "integration_points": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "target_subsystem": { "type": "string" },
          "method": { "type": "string" },
          "stage": { "type": "integer" }
        }
      }
    },
    "governance_enforcement_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "stage", "mechanism"],
        "properties": {
          "name": { "type": "string" },
          "stage": { "type": "integer" },
          "mechanism": { "type": "string" }
        }
      }
    },
    "error_handling": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "error_type": { "type": "string" },
          "cause": { "type": "string" },
          "response": { "type": "string" },
          "recovery": { "type": "string" }
        }
      }
    },
    "testing_strategy": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "test": { "type": "string" },
          "validates": { "type": "string" },
          "method": { "type": "string" }
        }
      }
    }
  }
}
