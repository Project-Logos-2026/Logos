{
  "schema_name": "PromptExecutionFeedback",
  "version": "1.0",
  "fields": {
    "execution_status": {
      "type": "string",
      "allowed_values": [
        "COMPLETE",
        "PARTIAL",
        "FAILED"
      ]
    },
    "exit_gate": {
      "type": "string",
      "description": "Indicates whether the exit condition for the prompt was satisfied"
    },
    "artifacts_generated": {
      "type": "array",
      "description": "List of files or artifacts produced by execution"
    },
    "warnings": {
      "type": "array",
      "description": "Non-blocking warnings generated during execution"
    },
    "pipeline_notes": {
      "type": "string",
      "description": "Notes generated by the execution agent"
    },
    "architectural_flags": {
      "type": "array",
      "description": "Architectural issues detected during execution"
    }
  },
  "decision_rules": {
    "COMPLETE": "Proceed to next prompt",
    "PARTIAL": "Revise prompt and retry",
    "FAILED": "Escalate to Architect or Claude",
    "ARCHITECTURAL_FLAG": "Pause pipeline and request architecture clarification"
  }
}