{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "archon_prime_design_spec_v2_schema",
  "title": "ARCHON_PRIME Design Specification Schema V2",
  "description": "Validates the structure of Design Specification artifacts. V2 closes architectural drift gaps identified in Phase-2 audit. Enforces canonical module identity, subsystem boundaries, artifact surface separation, header schema definition, enhancement governance, and implementation sequencing. Self-contained; references ARTIFACT_META_SCHEMA for shared definitions.",
  "version": "2.0",
  "authority": "ARCHON_PRIME_ARCHITECT",
  "source_directive": "ARCHON_PRIME_SCHEMA_REVISION_DIRECTIVE_v1 (Documents 1, 2, 3)",

  "type": "object",

  "required": [
    "spec_identity",
    "purpose",
    "functional_requirements",
    "constraints",
    "formal_model",
    "canonical_architecture",
    "canonical_module_registry",
    "module_identity_rules",
    "subsystem_contracts",
    "artifact_surface_definition",
    "module_classification_types",
    "header_schema_definition",
    "architecture_validation_rules",
    "governance_rules",
    "implementation_sequence",
    "enhancement_lifecycle",
    "verification_criteria"
  ],

  "properties": {

    "spec_identity": {
      "type": "object",
      "description": "Artifact identity block. Must be present and complete before any other section is populated.",
      "required": [
        "artifact_id",
        "subsystem",
        "version",
        "status",
        "source_concept",
        "author",
        "date"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^SPEC-[0-9]{3,4}$",
          "description": "Canonical artifact identifier. Pattern: SPEC-NNNN."
        },
        "subsystem": {
          "type": "string",
          "minLength": 1,
          "description": "The canonical subsystem this specification governs."
        },
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+$",
          "description": "Monotonically incrementing version. Must match prior_version + 1 on update."
        },
        "status": {
          "type": "string",
          "enum": ["draft", "under_review", "approved", "locked", "superseded", "deprecated", "rejected"]
        },
        "source_concept": {
          "type": "string",
          "description": "Reference to the Concept Artifact (CON-NNNN) this spec formalizes."
        },
        "author": {
          "type": "string",
          "description": "Platform and role that produced this spec (e.g., 'Claude / Formalization_Expert')."
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "approved_by": {
          "type": ["string", "null"],
          "description": "Must be populated before status can transition to 'approved' or 'locked'."
        },
        "authority_source": {
          "type": "string",
          "description": "Governance authority governing this artifact."
        }
      },
      "if": {
        "properties": { "status": { "enum": ["approved", "locked"] } }
      },
      "then": {
        "required": ["approved_by"],
        "properties": {
          "approved_by": { "type": "string", "minLength": 1 }
        }
      }
    },

    "lineage": {
      "type": "object",
      "description": "Provenance chain. Required when this spec supersedes a prior version or derives from an analog discovery.",
      "properties": {
        "concept_origin": { "type": ["string", "null"] },
        "analog_origin": { "type": ["string", "null"] },
        "prior_version": { "type": ["string", "null"] },
        "supersedes": {
          "type": ["string", "null"],
          "description": "Artifact ID of the spec this version replaces. Required if prior_version is populated."
        }
      }
    },

    "purpose": {
      "type": "string",
      "minLength": 1,
      "description": "What this subsystem exists to do. Scope statement."
    },

    "functional_requirements": {
      "type": "array",
      "minItems": 1,
      "description": "What the subsystem must do. Each requirement must be specific, testable, and traceable.",
      "items": {
        "type": "object",
        "required": ["id", "description", "source"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^FR-[0-9]{3}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "description": "Reference to concept artifact or authority source."
          },
          "testable": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },

    "constraints": {
      "type": "array",
      "minItems": 1,
      "description": "What the subsystem must not do or what limits it must respect.",
      "items": {
        "type": "object",
        "required": ["id", "description", "rationale"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^C-[0-9]{3}$"
          },
          "description": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "enforcement_mechanism": {
            "type": ["string", "null"],
            "description": "How this constraint is enforced at runtime or validation time."
          }
        }
      }
    },

    "formal_model": {
      "type": "object",
      "description": "Mathematical and structural definition of the subsystem.",
      "required": ["primitives", "operations", "axioms"],
      "properties": {
        "primitives": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Basic objects of the system."
        },
        "operations": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Transformations defined on primitives."
        },
        "axioms": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Constraints the system must satisfy."
        },
        "relations": {
          "type": "array",
          "items": { "type": "object" }
        },
        "properties": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },

    "canonical_architecture": {
      "type": "object",
      "description": "Explicit definition of the repository's canonical directory structure. Prevents module placement ambiguity. Every subsystem, directory, and allowed file type must be declared here.",
      "required": ["root", "directory_tree", "placement_rules"],
      "properties": {
        "root": {
          "type": "string",
          "description": "Canonical repository root path."
        },
        "directory_tree": {
          "type": "array",
          "minItems": 1,
          "description": "Exhaustive enumeration of all canonical directories.",
          "items": {
            "type": "object",
            "required": ["path", "subsystem", "surface", "allowed_file_types"],
            "properties": {
              "path": {
                "type": "string",
                "description": "Path relative to repository root."
              },
              "subsystem": {
                "type": "string",
                "description": "Subsystem this directory belongs to."
              },
              "surface": {
                "type": "string",
                "enum": [
                  "runtime_surface",
                  "artifact_archive_surface",
                  "design_surface",
                  "audit_surface",
                  "test_surface",
                  "tool_surface"
                ],
                "description": "Which artifact surface this directory belongs to."
              },
              "allowed_file_types": {
                "type": "array",
                "items": { "type": "string" },
                "description": "File extensions permitted in this directory (e.g., [\".py\", \".json\"])."
              },
              "description": { "type": ["string", "null"] }
            }
          }
        },
        "placement_rules": {
          "type": "array",
          "minItems": 1,
          "description": "Explicit rules governing where modules may and may not be placed.",
          "items": {
            "type": "object",
            "required": ["rule_id", "rule"],
            "properties": {
              "rule_id": {
                "type": "string",
                "pattern": "^PR-[0-9]{3}$"
              },
              "rule": { "type": "string" },
              "rationale": { "type": ["string", "null"] }
            }
          }
        }
      }
    },

    "canonical_module_registry": {
      "type": "object",
      "description": "Canonical identity of every module in this subsystem. Either inline or by reference. Inline is preferred for subsystem specs. Reference is used when registry is maintained as a separate artifact.",
      "required": ["registry_mode"],
      "properties": {
        "registry_mode": {
          "type": "string",
          "enum": ["inline", "reference"],
          "description": "'inline' embeds the registry. 'reference' points to an external registry artifact."
        },
        "registry_artifact_ref": {
          "type": ["string", "null"],
          "description": "Required when registry_mode == 'reference'. Artifact ID of the canonical registry."
        },
        "modules": {
          "type": "array",
          "description": "Required when registry_mode == 'inline'. Exhaustive list of canonical modules for this subsystem.",
          "items": {
            "type": "object",
            "required": [
              "module_id",
              "module_name",
              "canonical_path",
              "subsystem",
              "responsibility",
              "imports_allowed",
              "imports_forbidden"
            ],
            "properties": {
              "module_id": {
                "type": "string",
                "pattern": "^M[0-9]+$",
                "description": "Unique module identifier."
              },
              "module_name": {
                "type": "string",
                "description": "Canonical filename without extension."
              },
              "canonical_path": {
                "type": "string",
                "description": "Canonical path relative to repository root, including filename."
              },
              "subsystem": { "type": "string" },
              "responsibility": {
                "type": "string",
                "minLength": 1,
                "description": "Single-sentence functional description."
              },
              "runtime_stage": {
                "type": "string",
                "enum": ["initialization", "analysis", "processing", "validation", "repair", "audit", "reporting", "utility"],
                "description": "Which runtime stage this module participates in."
              },
              "dependencies": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Module IDs this module depends on."
              },
              "imports_allowed": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Subsystems or modules this module is permitted to import."
              },
              "imports_forbidden": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Subsystems or modules this module must never import."
              },
              "implementation_phase": {
                "type": "string",
                "description": "Implementation phase in which this module is built (e.g., 'PHASE_1')."
              },
              "spec_section_ref": {
                "type": ["string", "null"],
                "description": "Section of this spec that defines this module's behavior."
              }
            }
          }
        }
      },
      "if": {
        "properties": { "registry_mode": { "const": "inline" } }
      },
      "then": {
        "required": ["modules"],
        "properties": {
          "modules": { "minItems": 1 }
        }
      },
      "else": {
        "required": ["registry_artifact_ref"],
        "properties": {
          "registry_artifact_ref": { "type": "string", "minLength": 1 }
        }
      }
    },

    "module_identity_rules": {
      "type": "object",
      "description": "Rules that define when a module is considered canonically valid. A module is valid only if all three identity conditions are satisfied simultaneously.",
      "required": ["validity_conditions", "violation_classification"],
      "properties": {
        "validity_conditions": {
          "type": "array",
          "minItems": 3,
          "description": "All conditions must be satisfied for a module to be canonical.",
          "items": {
            "type": "object",
            "required": ["condition_id", "condition"],
            "properties": {
              "condition_id": {
                "type": "string",
                "pattern": "^IC-[0-9]{3}$"
              },
              "condition": { "type": "string" },
              "enforcement_point": {
                "type": "string",
                "enum": ["header_validation", "path_validation", "registry_check", "import_scan"],
                "description": "Where this condition is enforced."
              }
            }
          }
        },
        "violation_classification": {
          "type": "object",
          "description": "How identity violations are classified for the architecture validation report.",
          "required": ["categories"],
          "properties": {
            "categories": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["category", "description", "severity"],
                "properties": {
                  "category": { "type": "string" },
                  "description": { "type": "string" },
                  "severity": {
                    "type": "string",
                    "enum": ["blocking", "major", "minor"]
                  }
                }
              }
            }
          }
        }
      }
    },

    "subsystem_contracts": {
      "type": "array",
      "minItems": 1,
      "description": "Boundary definitions for every subsystem. Each contract defines what a subsystem may contain, what it may import, and what it must not import from adjacent subsystems.",
      "items": {
        "type": "object",
        "required": [
          "subsystem_id",
          "subsystem_name",
          "runtime_role",
          "allowed_modules",
          "allowed_imports",
          "forbidden_cross_imports"
        ],
        "properties": {
          "subsystem_id": { "type": "string" },
          "subsystem_name": { "type": "string" },
          "runtime_role": {
            "type": "string",
            "description": "The functional role of this subsystem in the runtime pipeline."
          },
          "allowed_modules": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Module IDs permitted to exist in this subsystem."
          },
          "allowed_imports": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Subsystems or modules this subsystem may import from."
          },
          "forbidden_cross_imports": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Subsystems this subsystem must never import from under any condition."
          },
          "controller_role": {
            "type": ["boolean", "null"],
            "description": "True if this subsystem contains orchestration or controller logic. Explicit declaration prevents controller proliferation."
          },
          "rationale": {
            "type": ["string", "null"],
            "description": "Why these boundaries are defined as they are."
          }
        }
      }
    },

    "artifact_surface_definition": {
      "type": "object",
      "description": "Defines the canonical artifact surfaces and which directories belong to each. Runtime code must never reside in non-runtime surfaces. Prevents the audit-surface contamination observed in AP v1.",
      "required": ["surfaces"],
      "properties": {
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["surface_id", "surface_name", "directories"],
            "properties": {
              "surface_id": { "type": "string" },
              "surface_name": {
                "type": "string",
                "enum": [
                  "runtime_surface",
                  "artifact_archive_surface",
                  "design_surface",
                  "audit_surface",
                  "test_surface",
                  "tool_surface"
                ]
              },
              "description": { "type": ["string", "null"] },
              "directories": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Canonical directory paths belonging to this surface."
              },
              "runtime_code_permitted": {
                "type": "boolean",
                "description": "Whether executable runtime code may reside in this surface. Must be false for all non-runtime surfaces."
              }
            }
          }
        },
        "isolation_rules": {
          "type": "array",
          "description": "Explicit cross-surface prohibition rules.",
          "items": {
            "type": "object",
            "required": ["rule_id", "prohibited_source_surface", "prohibited_target_surface", "description"],
            "properties": {
              "rule_id": { "type": "string" },
              "prohibited_source_surface": { "type": "string" },
              "prohibited_target_surface": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },

    "module_classification_types": {
      "type": "object",
      "description": "First-class architectural classification system for modules. Classification is assigned during architecture validation, not post-hoc. All classification types must be declared in the spec before implementation begins.",
      "required": ["classifications"],
      "properties": {
        "classifications": {
          "type": "array",
          "minItems": 7,
          "items": {
            "type": "object",
            "required": ["classification_id", "label", "description", "disposition"],
            "properties": {
              "classification_id": { "type": "string" },
              "label": {
                "type": "string",
                "enum": [
                  "SPEC_REQUIRED",
                  "SPEC_PRESENT",
                  "SPEC_MISSING",
                  "ANALOG_IMPLEMENTATION",
                  "ENHANCEMENT_MODULE",
                  "LEGACY_MODULE",
                  "UNKNOWN_MODULE"
                ]
              },
              "description": { "type": "string" },
              "disposition": {
                "type": "string",
                "enum": ["retain", "adopt", "wrap", "replace", "escalate", "flag_for_review"],
                "description": "Default disposition for modules of this classification."
              },
              "requires_architect_review": {
                "type": "boolean",
                "description": "Whether modules of this classification require explicit Architect review before disposition."
              }
            }
          }
        }
      }
    },

    "header_schema_definition": {
      "type": "object",
      "description": "Defines the mandatory machine-readable header block that every runtime module must contain. Header fields enable automated architecture validation, drift detection, and dependency graph generation. This makes the repository self-describing.",
      "required": ["required_fields", "header_format", "validation_rules"],
      "properties": {
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "description": "Every field in this list must be present in every runtime module header.",
          "items": {
            "type": "object",
            "required": ["field_name", "field_type", "description"],
            "properties": {
              "field_name": { "type": "string" },
              "field_type": {
                "type": "string",
                "enum": ["string", "string_list", "boolean", "enum"]
              },
              "description": { "type": "string" },
              "allowed_values": {
                "type": ["array", "null"],
                "items": { "type": "string" },
                "description": "Required for enum type fields. Constrains the allowed values."
              },
              "must_match_registry": {
                "type": "boolean",
                "description": "If true, this field must match the value in the canonical module registry for validation to pass."
              }
            }
          }
        },
        "header_format": {
          "type": "string",
          "description": "Canonical header format specification. Defines the exact structure parsers must expect.",
          "minLength": 1
        },
        "header_placement": {
          "type": "string",
          "enum": ["file_top", "after_shebang", "after_encoding_declaration"],
          "default": "file_top",
          "description": "Where in the file the header must appear."
        },
        "validation_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["rule_id", "rule", "violation_label"],
            "properties": {
              "rule_id": {
                "type": "string",
                "pattern": "^HVR-[0-9]{3}$"
              },
              "rule": { "type": "string" },
              "violation_label": {
                "type": "string",
                "description": "Label used in the architecture validation report for this violation type."
              }
            }
          }
        }
      }
    },

    "architecture_validation_rules": {
      "type": "object",
      "description": "Defines the mandatory architecture compliance validation checks. These checks must be automated and must run before any build, enhancement integration, or release step.",
      "required": ["validation_checks", "validation_gate_conditions"],
      "properties": {
        "validation_checks": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "required": ["check_id", "check_name", "description", "blocking"],
            "properties": {
              "check_id": {
                "type": "string",
                "pattern": "^AVR-[0-9]{3}$"
              },
              "check_name": { "type": "string" },
              "description": { "type": "string" },
              "blocking": {
                "type": "boolean",
                "description": "If true, validation failure on this check halts the pipeline."
              },
              "report_field": {
                "type": "string",
                "description": "The field in architecture_validation_report.json where violations are recorded."
              }
            }
          }
        },
        "validation_gate_conditions": {
          "type": "array",
          "description": "Pipeline stages that require a passing validation before they may proceed.",
          "items": {
            "type": "object",
            "required": ["gate_id", "stage", "condition"],
            "properties": {
              "gate_id": { "type": "string" },
              "stage": {
                "type": "string",
                "enum": [
                  "module_generation",
                  "enhancement_integration",
                  "release_build",
                  "repository_packaging",
                  "spec_update"
                ]
              },
              "condition": {
                "type": "string",
                "description": "The condition that must be true. Typically 'architecture_valid == true'."
              }
            }
          }
        },
        "validation_output_schema": {
          "type": "object",
          "description": "Schema definition for the architecture_validation_report.json artifact.",
          "properties": {
            "required_fields": {
              "type": "array",
              "items": { "type": "string" }
            },
            "output_path": { "type": "string" }
          }
        }
      }
    },

    "governance_rules": {
      "type": "object",
      "description": "Defines the governance rules that apply to this subsystem's spec and implementation lifecycle.",
      "required": [
        "non_deletion_policy",
        "architect_override_mechanism",
        "spec_change_process",
        "enhancement_proposal_process"
      ],
      "properties": {
        "non_deletion_policy": {
          "type": "object",
          "required": ["rule", "exceptions"],
          "properties": {
            "rule": {
              "type": "string",
              "description": "The non-deletion rule for canonical modules."
            },
            "exceptions": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Conditions under which deletion is permitted (e.g., explicit Architect authorization)."
            }
          }
        },
        "architect_override_mechanism": {
          "type": "object",
          "required": ["trigger", "process"],
          "properties": {
            "trigger": { "type": "string" },
            "process": { "type": "string" }
          }
        },
        "spec_change_process": {
          "type": "object",
          "required": ["steps"],
          "properties": {
            "steps": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Ordered steps required to modify this spec."
            }
          }
        },
        "enhancement_proposal_process": {
          "type": "object",
          "required": ["steps"],
          "properties": {
            "steps": {
              "type": "array",
              "items": { "type": "string" }
            },
            "blocking_rule": {
              "type": "string",
              "description": "Statement of the rule that prevents enhancements from being implemented before spec update."
            }
          }
        }
      }
    },

    "implementation_sequence": {
      "type": "object",
      "description": "Defines the mandatory order in which modules must be implemented. Prevents enhancements from being built before core architecture is stable.",
      "required": ["phases"],
      "properties": {
        "phases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["phase_id", "phase_name", "modules", "entry_condition"],
            "properties": {
              "phase_id": {
                "type": "string",
                "description": "Phase identifier (e.g., 'PHASE_1')."
              },
              "phase_name": { "type": "string" },
              "modules": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Module IDs to be implemented in this phase."
              },
              "entry_condition": {
                "type": "string",
                "description": "What must be true before this phase may begin."
              },
              "exit_condition": {
                "type": "string",
                "description": "What must be true before the next phase may begin."
              },
              "enhancements_permitted": {
                "type": "boolean",
                "default": false,
                "description": "Whether enhancement modules may be integrated during this phase. Default false."
              }
            }
          }
        },
        "sequence_enforcement": {
          "type": "object",
          "description": "Rules ensuring phase ordering is respected.",
          "properties": {
            "out_of_order_disposition": {
              "type": "string",
              "enum": ["halt", "warn", "log"],
              "default": "halt",
              "description": "What happens if implementation is attempted out of sequence."
            }
          }
        }
      }
    },

    "enhancement_lifecycle": {
      "type": "object",
      "description": "Governs the full lifecycle of enhancement modules. Enhancements must never be implemented directly into the repo before spec update. This rule is non-negotiable.",
      "required": ["stages", "pre_implementation_gate"],
      "properties": {
        "stages": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "required": ["stage_id", "stage_name", "required_output"],
            "properties": {
              "stage_id": {
                "type": "string",
                "pattern": "^EL-[0-9]{3}$"
              },
              "stage_name": {
                "type": "string",
                "enum": ["proposal", "review", "approval", "spec_update", "implementation"]
              },
              "required_output": {
                "type": "string",
                "description": "The artifact or decision that must exist before the next stage begins."
              },
              "authority": {
                "type": "string",
                "description": "Who or what governs this stage."
              }
            }
          }
        },
        "pre_implementation_gate": {
          "type": "object",
          "required": ["conditions"],
          "description": "All conditions must be true before an enhancement module may be committed to the repository.",
          "properties": {
            "conditions": {
              "type": "array",
              "minItems": 3,
              "items": { "type": "string" }
            }
          }
        },
        "bypass_rule": {
          "type": "object",
          "description": "Statement of whether and how the enhancement lifecycle may be bypassed.",
          "properties": {
            "bypassable": {
              "type": "boolean",
              "default": false,
              "description": "Whether bypass is ever permitted. Default false."
            },
            "bypass_conditions": {
              "type": ["array", "null"],
              "items": { "type": "string" }
            }
          }
        }
      }
    },

    "integration_surfaces": {
      "type": "array",
      "description": "How this subsystem connects to adjacent subsystems.",
      "items": {
        "type": "object",
        "required": ["adjacent_subsystem", "interface_type", "data_flow"],
        "properties": {
          "adjacent_subsystem": { "type": "string" },
          "interface_type": { "type": "string" },
          "data_flow": { "type": "string" }
        }
      }
    },

    "verification_criteria": {
      "type": "array",
      "minItems": 1,
      "description": "How to verify that an implementation correctly realizes this specification.",
      "items": {
        "type": "object",
        "required": ["id", "criterion", "method"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^V-[0-9]{3}$"
          },
          "criterion": { "type": "string" },
          "method": { "type": "string" },
          "automated": {
            "type": "boolean",
            "description": "Whether this criterion can be verified by the architecture validator."
          }
        }
      }
    },

    "deferments": {
      "type": "array",
      "description": "What is explicitly out of scope for this specification. Deferments are binding — deferred items must not be re-prioritized without Architect authorization.",
      "items": {
        "type": "object",
        "required": ["item", "rationale", "deferred_to"],
        "properties": {
          "item": { "type": "string" },
          "rationale": { "type": "string" },
          "deferred_to": {
            "type": "string",
            "description": "Phase, spec version, or artifact where this will be addressed."
          }
        }
      }
    },

    "open_questions": {
      "type": "array",
      "description": "Unresolved items requiring Architect decision. Must be resolved before spec may transition to 'approved'.",
      "items": {
        "type": "object",
        "required": ["question_id", "question", "blocking"],
        "properties": {
          "question_id": { "type": "string" },
          "question": { "type": "string" },
          "blocking": {
            "type": "boolean",
            "description": "Whether this question must be resolved before implementation may begin."
          },
          "resolution": {
            "type": ["string", "null"],
            "description": "Architect's resolution when provided."
          }
        }
      }
    },

    "revision_history": {
      "type": "array",
      "description": "Ordered change log. Append-only.",
      "items": {
        "type": "object",
        "required": ["version", "date", "change", "author"],
        "properties": {
          "version": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "change": { "type": "string" },
          "author": { "type": "string" }
        }
      }
    }
  },

  "meta_rules": {
    "description": "Schema-level enforcement rules. These apply to any artifact validated against this schema.",
    "rules": [
      {
        "rule_id": "MR-001",
        "rule": "Spec Before Code: implementation_guide_complete and design_spec_complete must both be true before implementation begins.",
        "enforcement": "blocking"
      },
      {
        "rule_id": "MR-002",
        "rule": "Enhancements must modify design_spec and implementation_guide before any code is committed.",
        "enforcement": "blocking"
      },
      {
        "rule_id": "MR-003",
        "rule": "Any module not matching the canonical_module_registry is flagged as UNKNOWN_MODULE or classified per module_classification_types.",
        "enforcement": "blocking"
      },
      {
        "rule_id": "MR-004",
        "rule": "Architecture validation gate: build pipeline cannot progress if architecture_valid == false.",
        "enforcement": "blocking"
      },
      {
        "rule_id": "MR-005",
        "rule": "Runtime modules may only exist in directories classified as runtime_surface.",
        "enforcement": "blocking"
      }
    ]
  },

  "additionalProperties": false
}
